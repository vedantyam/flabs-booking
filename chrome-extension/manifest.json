{
  "manifest_version": 3,
  "name": "FLABS Demo Booking",
  "version": "1.0",
  "description": "Automatically updates TeleCRM when you book a demo",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://next.telecrm.in/*",
    "https://flabs-booking-frontend.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://next.telecrm.in/*"],
      "js": ["telecrm-content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
